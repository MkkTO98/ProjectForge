# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.*

# Local build metadata
projectforge.egg-info/
*.egg-info/

# Logs and runtime outputs
logs/raw/*
logs/derived/*
logs/index/*
logs/agents/*
!logs/raw/.gitkeep
!logs/derived/.gitkeep
!logs/index/.gitkeep
!logs/agents/.gitkeep

# Agent queues
question_queue/pending/*
question_queue/answered/*
question_queue/archive/*
!question_queue/pending/.gitkeep
!question_queue/answered/.gitkeep
!question_queue/archive/.gitkeep

# Generated projects, workspace checkouts, workspace-local backups, and local external-source mirrors
/generated/
workspace/projects/*
workspace/backups/
external_sources/
!workspace/projects/_SUMMARY.md
!workspace/projects/.gitkeep

# Runtime/test caches and generated dry-run/context reports
.pytest_cache/
simulation/dry_runs/*.md
!simulation/dry_runs/README.md
!simulation/dry_runs/_SUMMARY.md
context/active_context.md
context/context_audit.json
context/context_audit.md
context/context_manifest.json

# OS/editor
.DS_Store
.vscode/
.idea/
